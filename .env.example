# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# BREVO_API_KEY: A API key do servidor Brevo para o envio de e-mails marketing de captação.
BREVO_API_KEY="your_brevo_api_key_here"
SENDINBLUE_API_KEY="your_brevo_api_key_here"

# OPENROUTER_API_KEY: A chave de API da OpenRouter para a inteligência artificial.
OPENROUTER_API_KEY="your_openrouter_api_key_here"

# Firebase Principal (gestaopro-761e1)
VITE_FIREBASE_API_KEY_PRINCIPAL=
VITE_FIREBASE_APP_ID_PRINCIPAL=
VITE_FIREBASE_AUTH_DOMAIN_PRINCIPAL=
VITE_FIREBASE_PROJECT_ID_PRINCIPAL=
VITE_FIREBASE_STORAGE_BUCKET_PRINCIPAL=
VITE_FIREBASE_MESSAGING_SENDER_ID_PRINCIPAL=

# Firebase Comercial (gestaodeleadspro-d4230)
VITE_FIREBASE_API_KEY_COMERCIAL=
VITE_FIREBASE_APP_ID_COMERCIAL=
VITE_FIREBASE_AUTH_DOMAIN_COMERCIAL=
VITE_FIREBASE_PROJECT_ID_COMERCIAL=
VITE_FIREBASE_STORAGE_BUCKET_COMERCIAL=
VITE_FIREBASE_MESSAGING_SENDER_ID_COMERCIAL=
